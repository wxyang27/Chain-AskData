# ============================================================
# Chain-AskData Environment Template
# ============================================================
# Copy this file to .env, then fill in the keys you actually use.
# Do not commit real API keys.

# ------------------------------------------------------------
# LLM / Qwen compatible API
# ------------------------------------------------------------
LLM_ENABLED=true
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_dashscope_api_key
LLM_TIMEOUT_SECONDS=60

LLM_KEYWORD_MODEL=qwen-plus
LLM_COT_MODEL=qwen-plus
LLM_SQL_MODEL=qwen-plus
LLM_ROUTER_MODEL=qwen-plus
LLM_VALIDATOR_MODEL=qwen-plus
LLM_SUMMARY_MODEL=qwen-plus

# Optional role aliases. If set, they override LLM_COT_MODEL / LLM_SQL_MODEL.
# Use the exact model id enabled in your DashScope workspace.
# LLM_THINKING_MODEL=qwen3-vl-30b-a3b-thinking
# LLM_CODER_MODEL=qwen3-coder-next

# If you only want local deterministic tests, set:
# LLM_ENABLED=false
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=EMPTY

# ------------------------------------------------------------
# DashScope shared credentials
# ------------------------------------------------------------
# Required for EMBEDDING_PROVIDER=dashscope or RERANK_PROVIDER=dashscope.
DASHSCOPE_API_KEY=your_dashscope_api_key

# Required by qwen-rerank / qwen3-rerank workspace-compatible endpoint.
# You can find it in Alibaba Cloud Bailian workspace settings.
DASHSCOPE_WORKSPACE_ID=your_workspace_id

# ------------------------------------------------------------
# Embedding provider
# ------------------------------------------------------------
# local: deterministic HashEmbedding, no network, stable for tests.
# dashscope: text-embedding-v4, semantic vector recall, requires API key.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=hash-128
EMBEDDING_DIMENSION=128
EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings

# DashScope embedding example, requires rebuilding indexes:
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSION=1024
# python -m app.schema_indexing.build_indexes

# Legacy switch kept for compatibility; provider is the effective setting.
EMBEDDING_ENABLED=false

# ------------------------------------------------------------
# Rerank provider
# ------------------------------------------------------------
# local: LightweightReranker, metadata-aware lexical rerank.
# dashscope: qwen-rerank / qwen3-rerank, requires API key and usually workspace id.
RERANK_PROVIDER=local
RERANK_MODEL=lightweight
RERANK_TOP_N=20
RERANK_URL=
RERANK_ENDPOINT_MODE=auto

# DashScope rerank example:
# RERANK_PROVIDER=dashscope
# RERANK_MODEL=qwen3-rerank
# RERANK_ENDPOINT_MODE=compatible
# RERANK_URL=https://your_workspace_id.cn-beijing.maas.aliyuncs.com/compatible-api/v1/reranks
# If qwen3-rerank is unavailable, try:
# RERANK_MODEL=qwen-rerank

# Legacy switch kept for compatibility; provider is the effective setting.
RERANK_ENABLED=false

# ------------------------------------------------------------
# ChromaDB
# ------------------------------------------------------------
# If left unset in code, ChromaDB is automatically isolated by embedding model:
# data/chroma/local_hash_128
# data/chroma/dashscope_text_embedding_v4_1024
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=chain_askdata_knowledge

# ------------------------------------------------------------
# SQL execution layer
# ------------------------------------------------------------
# disabled: default, never executes SQL; safest for interviews/tests.
# mock: dry-run closed-loop demo, returns deterministic sample rows.
# sqlite: executes against a local SQLite demo DB.
# maxcompute/odps: read-only PyODPS executor for real MaxCompute SELECT/WITH queries.
EXECUTION_MODE=disabled
EXECUTION_TIMEOUT_SECONDS=30
EXECUTION_MAX_ROWS=100
EXECUTION_SQLITE_PATH=runtime_data/trade_demo.db

# MaxCompute / PyODPS credentials. Keep real values only in local .env.
ODPS_ACCESS_ID=your_odps_access_id
ODPS_SECRET_ACCESS_KEY=your_odps_secret_access_key
ODPS_PROJECT_NAME=soyoung_dw
# Public endpoint. Use aliyun.com, not aliyun-inc.com, when running outside Alibaba intranet.
ODPS_ENDPOINT=http://service.cn-beijing.maxcompute.aliyun.com/api
# Optional.
ODPS_LOGVIEW_HOST=

# ------------------------------------------------------------
# Feishu / Lark CatData bot long connection
# ------------------------------------------------------------
# Used by: python -m app.feishu_bot.runner
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_feishu_app_secret
# Optional for webhook/event compatibility; long-connection mode mainly needs App ID/Secret.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_EVENT_ENCRYPTED=false
FEISHU_REPLY_ENABLED=true
FEISHU_MAX_REPLY_CHARS=3500
# Keep SQL hidden in Feishu by default; set true when debugging.
FEISHU_INCLUDE_SQL=false
# Use Feishu Card 2.0 for bot replies; falls back to markdown if card sending fails.
FEISHU_CARD_ENABLED=true
# In groups, only respond when CatData is explicitly @-mentioned.
FEISHU_GROUP_REQUIRE_MENTION=true
# Turn on temporarily when diagnosing missing group events.
FEISHU_RAW_EVENT_LOG=false

# Optional: write CatData runtime logs into Feishu Base.
FEISHU_LOG_ENABLED=true
FEISHU_LOG_BASE_TOKEN=your_base_token
FEISHU_LOG_TABLE_ID=your_table_id
FEISHU_LOG_CLI=lark-cli
FEISHU_LOG_IDENTITY=user
