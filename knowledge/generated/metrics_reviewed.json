  {
    "asset_id": "metric:A019",
    "asset_type": "metric",
    "metric_type": "atomic",
    "metric_id": "A019",
    "name": "相控微针升单率",
    "english_name": "micro_needle_upsell_rate",
    "business_domain": "核销",
    "definition": "统计周期内，原单为相控微针且当日发生升单的核销人次/相控微针原单核销人次",
    "formula": "升单人次 / 原单核销人次",
    "data_type": "DECIMAL",
    "unit": "%",
    "source_tables": [
      "soyoung_dw.dm_opt_qy_user_execution_record_all_d"
    ],
    "sql": "SELECT a.standard_name,\n       COUNT(DISTINCT IF(b.verify_date_id IS NOT NULL,a.verify_date_id,NULL))\n       / COUNT(DISTINCT a.verify_date_id) 升单率\nFROM (\n    SELECT standard_name, verify_date_id\n    FROM soyoung_dw.dm_opt_qy_user_execution_record_all_d\n    WHERE dp = DATE_SUB(current_date(),1)\n    AND is_valid = 1\n    AND standard_name REGEXP '相控微针'\n    AND ord_up_type_name = '原单'\n) a\nLEFT JOIN (\n    SELECT standard_name, verify_date_id\n    FROM soyoung_dw.dm_opt_qy_user_execution_record_all_d\n    WHERE dp = DATE_SUB(current_date(),1)\n    AND ord_up_type_name = '升单'\n    AND is_valid = 1\n) b ON a.verify_date_id = b.verify_date_id\nGROUP BY a.standard_name\n",
    "derived_metric_count": 0,
    "dashboard_names": [],
    "notes": "",
    "review_status": "reviewed",
    "source_kind": "feishu_dict_yaml",
    "source_file": "metrics_from_feishu_dict.yaml",
    "source_sheet": "atomic_metrics",
    "source_row": "A019"
